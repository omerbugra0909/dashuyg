@model List<Kategori>

<div class="container mt-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">📚 Kategori Yönetimi</h2>

        <a asp-action="Ekle" class="btn btn-success btn-lg">
            ➕ Yeni Kategori
        </a>
    </div>

    <div class="card shadow-lg border-0">
        <div class="card-header bg-dark text-white">
            <h5 class="mb-0">Kategoriler</h5>
        </div>

        <div class="card-body p-0">

            <table class="table table-hover table-striped align-middle mb-0">

                <thead class="table-dark">
                    <tr>
                        <th style="width:80px">ID</th>
                        <th>Kategori Adı</th>
                        <th style="width:200px">Oluşturma Tarihi</th>
                        <th style="width:220px">İşlemler</th>
                    </tr>
                </thead>

                <tbody>

                    @if (Model.Count == 0)
                    {
                        <tr>
                            <td colspan="4" class="text-center p-4">
                                Henüz kategori eklenmemiş.
                            </td>
                        </tr>
                    }

                    @foreach (var k in Model)
                    {
                        <tr>

                            <td>
                                <span class="badge bg-secondary">@k.Id</span>
                            </td>

                            <td class="fw-semibold">
                                @k.Ad
                            </td>

                            <td>
                                @k.OlusturmaTarihi.ToString("dd.MM.yyyy")
                            </td>

                            <td>

                                <a asp-action="Guncelle"
                                   asp-route-id="@k.Id"
                                   class="btn btn-warning btn-sm">
                                    ✏️ Düzenle
                                </a>

                                <a asp-action="Sil"
                                   asp-route-id="@k.Id"
                                   class="btn btn-danger btn-sm"
                                   onclick="return confirm('Silmek istediğine emin misin?')">
                                    🗑 Sil
                                </a>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>
    </div>

</div>