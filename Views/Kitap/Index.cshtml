@model IEnumerable<Kitap>

@{
    ViewData["Title"] = "Kitaplar";
}

<h1 class="mb-4 text-center">📚 Kitap Koleksiyonu</h1>

<div class="text-center mb-4">
    <a class="btn btn-lg btn-primary" href="@Url.Action("Ekle")">
        <i class="bi bi-plus-circle"></i> Yeni Kitap Ekle
    </a>
</div>

<div class="row row-cols-1 row-cols-md-3 g-4">
    @foreach (var kitap in Model)
    {
        <div class="col">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title">@kitap.Ad</h5>
                    <p class="card-text mb-1"><strong>Yazar:</strong> @kitap.Yazar</p>
                    <p class="card-text"><strong>Sayfa:</strong> @kitap.SayfaSayisi</p>

                    <div class="mt-auto d-flex justify-content-between">
                        <a class="btn btn-sm btn-warning" href="@Url.Action("Guncelle", new { id = kitap.Id })">
                            <i class="bi bi-pencil-square"></i> Güncelle
                        </a>
                        <a class="btn btn-sm btn-danger" href="@Url.Action("Sil", new { id = kitap.Id })"
                           onclick="return confirm('Bu kitabı silmek istediğinize emin misiniz?');">
                            <i class="bi bi-trash"></i> Sil
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<!-- Bootstrap Icons ve Script -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">