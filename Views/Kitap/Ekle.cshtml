@model Kitap

<h2>Kitap Ekle</h2>

<form asp-action="Ekle" method="post">
    <div class="form-group mb-3">
        <label>Kitap Adı</label>
        <input asp-for="Ad" class="form-control" />
        <span asp-validation-for="Ad" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label>Yazar</label>
        <input asp-for="Yazar" class="form-control" />
        <span asp-validation-for="Yazar" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label>Sayfa Sayısı</label>
        <input asp-for="SayfaSayisi" type="number" class="form-control" />
        <span asp-validation-for="SayfaSayisi" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label>Kategori</label>
        <select asp-for="KategoriId" class="form-control" asp-items="@(new SelectList(ViewBag.Kategoriler, "Id", "Ad"))">
            <option value="">-- Kategori Seç --</option>
        </select>
        <span asp-validation-for="KategoriId" class="text-danger"></span>
    </div>

    <button class="btn btn-success">Kaydet</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}