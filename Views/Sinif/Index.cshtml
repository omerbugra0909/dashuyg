@model List<Sinif>

@{
    ViewData["Title"] = "Sınıflar";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">🏫 Sınıf Yönetimi</h2>
        <a asp-action="Ekle" class="btn btn-success btn-lg">➕ Yeni Sınıf</a>
    </div>

    <div class="card shadow-lg border-0">
        <div class="card-header bg-dark text-white">
            <h5 class="mb-0">Sınıflar</h5>
        </div>

        <div class="card-body p-0">
            <table class="table table-hover table-striped align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th style="width:80px">ID</th>
                        <th>Sınıf Adı</th>
                        <th style="width:160px">Öğrenci Sayısı</th>
                        <th style="width:200px">Oluşturma Tarihi</th>
                        <th style="width:220px">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Count == 0)
                    {
                        <tr>
                            <td colspan="5" class="text-center p-4">
                                Henüz sınıf eklenmemiş.
                            </td>
                        </tr>
                    }

                    @foreach (var s in Model)
                    {
                        <tr>
                            <td><span class="badge bg-secondary">@s.Id</span></td>
                            <td class="fw-semibold">@s.Ad</td>
                            <td>@s.Ogrenciler.Count</td>
                            <td>@s.OlusturmaTarihi.ToString("dd.MM.yyyy")</td>
                            <td>
                                <a asp-action="Guncelle" asp-route-id="@s.Id" class="btn btn-warning btn-sm">✏️ Düzenle</a>
                                <a asp-action="Sil" asp-route-id="@s.Id" class="btn btn-danger btn-sm"
                                   onclick="return confirm('Silmek istediğine emin misin?')">🗑 Sil</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
